<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>BUNGSU MART - Sistem Pencatatan</title>
<style>
  /* ==================== GLOBAL STYLES ==================== */
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #121212;
    color: #eee;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    padding: 10px;
  }
  #app {
    background-color: #181818;
    width: 360px;
    height: 480px;
    border-radius: 20px;
    box-shadow: 0 0 15px #222;
    display: flex;
    flex-direction: column;
    padding: 15px 20px;
    position: relative;
    overflow: hidden;
  }
  
  /* ==================== NAVIGATION ==================== */
  nav.bottom-nav {
    position: absolute;
    bottom: 12px;
    left: 20px;
    right: 20px;
    display: flex;
    justify-content: space-around;
    background-color: #222;
    border-radius: 15px;
    padding: 6px 8px;
  }
  nav.bottom-nav button {
    background: none;
    border: none;
    color: #888;
    font-size: 0.7rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 4px 8px;
    border-radius: 10px;
    transition: all 0.2s;
  }
  nav.bottom-nav button span {
    font-size: 1.1rem;
  }
  nav.bottom-nav button.active {
    background-color: #308446;
    color: #fff;
  }
  /* Hide bottom nav on certain pages */
  .no-nav nav.bottom-nav { display: none; }

  /* ==================== PAGES TRANSITION ==================== */
  .page {
    display: none;
    flex-direction: column;
    flex-grow: 1;
    overflow-y: auto;
    padding-bottom: 45px;
  }
  .page.active {
    display: flex;
  }

  /* ==================== HOME PAGE ==================== */
  #home-page header {
    margin-bottom: 12px;
  }
  #home-page header h1 {
    font-weight: 700;
    font-size: 1.8rem;
  }
  #home-page header small {
    font-weight: 400;
    color: #888;
  }
  #home-page #tanggal {
    margin: 8px 0 24px;
    font-weight: 500;
    font-size: 1rem;
    color: #aaa;
  }
  #home-page .menu-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  #home-page .card-menu {
    display: flex;
    align-items: center;
    padding: 16px 20px;
    border-radius: 15px;
    cursor: pointer;
    transition: background 0.25s ease;
    box-shadow: 0 2px 5px rgba(0,0,0,0.6);
  }
  #home-page .card-menu:hover {
    filter: brightness(1.1);
  }
  #home-page .icon-container {
    font-size: 30px;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    margin-right: 18px;
  }
  #home-page .card-text h2 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
  }
  #home-page .card-text small {
    font-weight: 400;
    color: #bbb;
  }
  #home-page .arrow-icon {
    font-weight: 700;
    font-size: 22px;
    color: #eee;
  }
  /* Colors */
  .purple-bg { background: #6a4c93; }
  .green-bg { background: #308446; }
  .orange-bg { background: #cc6c23; }
  /* Footer */
  #home-page footer {
    margin-top: auto;
    font-size: 0.78rem;
    color: #666;
    text-align: center;
  }
  #home-page footer .storage-info {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    font-size: 0.7rem;
    color: #44aa44;
    margin-top: 4px;
  }

  /* ==================== SOLD OUT PAGE ==================== */
  #soldout-page label {
    color: #6a4c93;
    font-weight: 600;
    cursor: pointer;
    display: inline-block;
    margin-bottom: 4px;
  }
  #soldout-page input[type="text"] {
    width: 100%;
    padding: 8px 12px;
    font-size: 1rem;
    border-radius: 8px;
    border: none;
    outline: none;
    background-color: #222;
    color: #eee;
    margin-bottom: 10px;
  }
  #soldout-page button {
    border: none;
    font-weight: 700;
    border-radius: 10px;
    cursor: pointer;
    padding: 10px;
    width: 100%;
    margin-bottom: 8px;
    user-select: none;
  }
  #soldout-page #btnSimpan {
    background-color: #6a4c93;
    color: #fff;
  }
  #soldout-page #btnSimpan:disabled {
    background-color: #3a2a4a;
    cursor: not-allowed;
  }
  #soldout-page #searchBarang {
    padding: 6px 12px;
    margin: 10px 0 12px;
  }
  #soldout-page .list-container {
    flex-grow: 1;
    overflow-y: auto;
    padding-right: 4px;
  }
  #soldout-page .item-barang {
    display: flex;
    justify-content: space-between;
    background-color: #222;
    margin-bottom: 8px;
    padding: 8px 10px;
    border-radius: 10px;
    align-items: center;
  }
  #soldout-page .item-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  #soldout-page .btn-plus, #soldout-page .btn-delete {
    cursor: pointer;
    font-weight: 700;
    font-size: 18px;
    width: 28px;
    height: 28px;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 6px;
    border: none;
    user-select: none;
  }
  #soldout-page .btn-plus {
    background-color: #6a4c93;
    color: #fff;
  }
  #soldout-page .btn-delete {
    background-color: #a00;
    color: #fff;
    font-size: 14px;
  }
  #soldout-page #listHabis {
    margin-top: 10px;
  }
  #soldout-page #listHabis h3 {
    color: #888;
    font-weight: 600;
    margin-bottom: 6px;
    font-size: 0.95rem;
  }
  #soldout-page #listHabis ol {
    padding-left: 20px;
    margin: 0;
    max-height: 70px;
    overflow-y: auto;
  }
  #soldout-page #listHabis li {
    margin-bottom: 3px;
    font-size: 0.9rem;
  }
  #soldout-page .btm-btn {
    margin-top: 8px;
  }
  #soldout-page #btnKirimWA {
    background-color: #6a4c93;
    color: #fff;
  }
  #soldout-page #btnKirimWA:disabled {
    background-color: #3a2a4a;
    cursor: not-allowed;
  }
  #soldout-page #btnHapusSemua { background-color: #a00; color: white; }
  #soldout-page #btnUndo { background-color: #cc7a00; color: black; }

  /* ==================== PENGELUARAN TOKO PAGE ==================== */
  #tokopedia-page label {
    display: block;
    margin-bottom: 4px;
    font-weight: 600;
  }
  #tokopedia-page input {
    width: 100%;
    padding: 8px 12px;
    font-size: 1rem;
    border-radius: 8px;
    border: none;
    outline: none;
    background-color: #222;
    color: #eee;
    margin-bottom: 12px;
  }
  #tokopedia-page button {
    border: none;
    font-weight: 700;
    border-radius: 10px;
    cursor: pointer;
    padding: 10px;
    margin-top: 8px;
    width: 100%;
    user-select: none;
  }
  #tokopedia-page #btnTambah {
    background-color: #308446;
    color: #111;
  }
  #tokopedia-page #btnTambah:disabled {
    background-color: #1a3322;
    cursor: not-allowed;
  }
  #tokopedia-page table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  #tokopedia-page thead th {
    color: #bbb;
    border-bottom: 1px solid #444;
    text-align: left;
    padding: 4px 6px;
  }
  #tokopedia-page tbody td {
    padding: 6px 4px;
    border-bottom: 1px solid #333;
  }
  #tokopedia-page tbody td.aksi {
    text-align: center;
  }
  #tokopedia-page .btn-delete {
    background-color: #a00;
    color: #fff;
    border: none;
    border-radius: 6px;
    width: 28px;
    height: 28px;
    font-size: 14px;
    cursor: pointer;
  }
  #tokopedia-page #totalContainer {
    margin-top: 8px;
    font-weight: 700;
    font-size: 1rem;
    text-align: right;
    color: #308446;
  }
  #tokopedia-page .btm-btn {
    margin-top: 8px;
  }
  #tokopedia-page #btnKirimWA {
    background-color: #308446;
    color: #111;
  }
  #tokopedia-page #btnKirimWA:disabled {
    background-color: #1a3322;
    cursor: not-allowed;
  }
  #tokopedia-page #btnHapusSemua { background-color: #a00; color: white; }
  #tokopedia-page #btnRiwayat { background-color: #176af7; color: white; }

  /* ==================== PENGELUARAN SARAPAN PAGE ==================== */
  #sarapan-page label {
    display: block;
    margin-bottom: 4px;
    font-weight: 600;
  }
  #sarapan-page input {
    width: 100%;
    padding: 8px 12px;
    font-size: 1rem;
    border-radius: 8px;
    border: none;
    outline: none;
    background-color: #222;
    color: #eee;
    margin-bottom: 12px;
  }
  #sarapan-page button {
    border: none;
    font-weight: 700;
    border-radius: 10px;
    cursor: pointer;
    padding: 10px;
    margin-top: 8px;
    width: 100%;
    user-select: none;
  }
  #sarapan-page #btnTambah {
    background-color: #cc6c23;
    color: #111;
  }
  #sarapan-page #btnTambah:disabled {
    background-color: #6b3612;
    cursor: not-allowed;
  }
  #sarapan-page table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  #sarapan-page thead th {
    color: #bbb;
    border-bottom: 1px solid #444;
    text-align: left;
    padding: 4px 6px;
  }
  #sarapan-page tbody td {
    padding: 6px 4px;
    border-bottom: 1px solid #333;
  }
  #sarapan-page tbody td.aksi {
    text-align: center;
  }
  #sarapan-page .btn-delete {
    background-color: #a00;
    color: #fff;
    border: none;
    border-radius: 6px;
    width: 28px;
    height: 28px;
    font-size: 14px;
    cursor: pointer;
  }
  #sarapan-page #totalContainer {
    margin-top: 8px;
    font-weight: 700;
    font-size: 1rem;
    text-align: right;
    color: #cc6c23;
  }
  #sarapan-page .btm-btn {
    margin-top: 8px;
  }
  #sarapan-page #btnKirimWA {
    background-color: #cc6c23;
    color: #111;
  }
  #sarapan-page #btnKirimWA:disabled {
    background-color: #6b3612;
    cursor: not-allowed;
  }
  #sarapan-page #btnHapusSemua { background-color: #a00; color: white; }
  #sarapan-page #btnRiwayat { background-color: #176af7; color: white; }

  /* ==================== RIWAYAT PAGE ==================== */
  #riwayat-page #tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
  }
  #riwayat-page .tab {
    flex-grow: 1;
    padding: 8px 0;
    border-radius: 10px;
    text-align: center;
    cursor: pointer;
    font-weight: 600;
    background-color: #222;
  }
  #riwayat-page .tab.active {
    background-color: #308446;
    color: #fff;
  }
  #riwayat-page #historyList {
    flex-grow: 1;
    overflow-y: auto;
    background-color: #222;
    border-radius: 12px;
    padding: 10px;
  }
  #riwayat-page .history-item {
    display: flex;
    justify-content: space-between;
    background-color: #2c2c2c;
    margin-bottom: 8px;
    padding: 10px 14px;
    border-radius: 8px;
    cursor: pointer;
    align-items: center;
  }
  #riwayat-page .history-item:hover {
    background-color: #3a6e39;
  }
  #riwayat-page .date-text { font-weight: 600; }
  #riwayat-page .total-text { font-weight: 700; color: #308446; }
  #riwayat-page.sarapan .total-text { color: #cc6c23; }

  /* ==================== KELOLA BARANG PAGE ==================== */
  #kelola-page input {
    width: 100%;
    padding: 8px 12px;
    font-size: 1rem;
    border-radius: 8px;
    border: none;
    background-color: #222;
    color: #eee;
    margin-bottom: 12px;
  }
  #kelola-page #listBarang {
    flex-grow: 1;
    background-color: #222;
    border-radius: 12px;
    padding: 10px 12px;
    overflow-y: auto;
  }
  #kelola-page .item-barang {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: #2c2c2c;
    margin-bottom: 8px;
    padding: 10px 12px;
    border-radius: 8px;
  }
  #kelola-page .nama-barang { font-weight: 600; }
  #kelola-page button.delete-btn {
    background-color: #a00;
    border: none;
    color: white;
    cursor: pointer;
    font-weight: 700;
    border-radius: 8px;
    padding: 6px 10px;
  }
  #kelola-page #btnTambahBaru {
    background-color: #176af7;
    border: none;
    color: white;
    font-weight: 700;
    border-radius: 12px;
    padding: 12px;
    cursor: pointer;
    margin-top: 10px;
  }

  /* ==================== FITUR PAGE ==================== */
  #fitur-page ul {
    list-style: none;
    padding-left: 0;
  }
  #fitur-page li {
    position: relative;
    padding-left: 28px;
    margin-bottom: 14px;
    line-height: 1.4;
    font-weight: 600;
  }
  #fitur-page li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #44aa44;
    font-weight: bold;
  }

  /*
